# Normalise line endings to LF in the repo; check out as-is on all platforms.
* text=auto eol=lf

# Force binary files to never be mangled.
*.png binary
*.jpg binary
*.gif binary
*.ico binary
*.pdf binary
*.zip binary
*.tar binary
*.gz  binary
*.exe binary
*.dll binary
*.so  binary
*.a   binary
*.lib binary
*.obj binary
*.o   binary
*.pyd binary

# CMake + C/C++ source: always LF
*.cmake   text eol=lf
CMakeLists.txt text eol=lf
*.h   text eol=lf
*.hpp text eol=lf
*.cpp text eol=lf
*.c   text eol=lf
*.cu  text eol=lf

# Markdown, YAML, JSON: always LF
*.md   text eol=lf
*.yaml text eol=lf
*.yml  text eol=lf
*.json text eol=lf

# Python: always LF
*.py text eol=lf

# Shell: always LF
*.sh   text eol=lf
*.bash text eol=lf

# Windows scripts: CRLF on checkout
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

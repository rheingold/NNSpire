{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build engine-ninja",
            "type": "shell",
            "command": "C:/Users/plachy/Documents/Dev/Qt/Tools/CMake_64/bin/cmake.exe",
            "args": ["--build", "--preset", "engine-ninja"],
            "options": {
                "cwd": "${workspaceFolder}/nnstudio"
            },
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": "absolute",
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            }
        },
        {
            "label": "Configure engine-ninja",
            "type": "shell",
            "command": "C:/Users/plachy/Documents/Dev/Qt/Tools/CMake_64/bin/cmake.exe",
            "args": ["--preset", "engine-ninja"],
            "options": {
                "cwd": "${workspaceFolder}/nnstudio"
            },
            "problemMatcher": []
        },
        {
            "label": "Run tests (ctest)",
            "type": "shell",
            "command": "C:/Users/plachy/Documents/Dev/Qt/Tools/CMake_64/bin/ctest.exe",
            "args": ["--preset", "engine-ninja", "--output-on-failure"],
            "options": {
                "cwd": "${workspaceFolder}/nnstudio"
            },
            "group": "test",
            "problemMatcher": []
        }
    ]
}

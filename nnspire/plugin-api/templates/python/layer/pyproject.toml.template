[build-system]
requires = ["hatchling"]
build-backend = "hatchling.build"

[project]
name = "{{PLUGIN_ID_SNAKE}}"
version = "{{PLUGIN_VERSION}}"
description = "{{PLUGIN_DESCRIPTION}}"
authors = [{ name = "{{PLUGIN_AUTHOR}}", url = "{{PLUGIN_AUTHOR_URL}}" }]
license = { text = "{{PLUGIN_LICENSE}}" }
readme = "README.md"
requires-python = ">=3.10"

# NNSpire Python bridge is required at runtime
dependencies = [
    "NNSpire>=1.0.0",
]

[project.optional-dependencies]
dev = [
    "pytest",
    "NNSpire",
]

[tool.hatch.build.targets.wheel]
packages = ["{{PLUGIN_ID_SNAKE}}"]
